                <button onclick="showPage('ai')" class="nav-btn px-4 py-2 rounded-md text-sm font-bold text-yellow-300 hover:text-yellow-100 hover:bg-blue-800 transition flex items-center gap-2 border border-yellow-400/30" id="nav-ai">
